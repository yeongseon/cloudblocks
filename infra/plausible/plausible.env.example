# Plausible CE — Local Development Environment
# Copy to plausible.env before running docker compose.

# Required: Generate with `openssl rand -base64 48`
SECRET_KEY_BASE=replace-me-with-a-random-64-char-string

# Base URL where Plausible will be accessible
BASE_URL=http://localhost:8100

# Disable email verification for local dev
DISABLE_REGISTRATION=invite_only
