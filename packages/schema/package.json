{
  "name": "@cloudblocks/schema",
  "version": "0.16.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:schema": "tsx scripts/generate-schema.ts"
  },
  "devDependencies": {
    "ts-json-schema-generator": "^2.4.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
