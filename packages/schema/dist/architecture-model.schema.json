{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ArchitectureModel",
  "definitions": {
    "ArchitectureModel": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "User-facing architecture revision (not schema version)"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ResourceNode"
          },
          "description": "All nodes — containers and resources in a flat array"
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Connection"
          }
        },
        "externalActors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalActor"
          }
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO 8601"
        }
      },
      "required": [
        "id",
        "name",
        "version",
        "nodes",
        "connections",
        "externalActors",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false,
      "description": "The root ArchitectureModel — the single most important type. This is the canonical JSON wire format exchanged between frontend persistence, backend validation, and code generation."
    },
    "ResourceNode": {
      "anyOf": [
        {
          "$ref": "#/definitions/ContainerNode"
        },
        {
          "$ref": "#/definitions/LeafNode"
        }
      ],
      "description": "Discriminated union of all node types in the architecture. Discriminant: `kind` field ('container' | 'resource')."
    },
    "ContainerNode": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "container"
        },
        "layer": {
          "$ref": "#/definitions/LayerType",
          "description": "Hierarchy layer — used for containment validation"
        },
        "resourceType": {
          "type": "string",
          "description": "Specific resource identifier, e.g. 'virtual_network', 'vm', 'sql_database'"
        },
        "category": {
          "$ref": "#/definitions/ResourceCategory",
          "description": "One of the 7 resource categories"
        },
        "provider": {
          "$ref": "#/definitions/ProviderType"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent node ID. null for root-level nodes."
        },
        "position": {
          "$ref": "#/definitions/Position"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        },
        "config": {
          "type": "object",
          "additionalProperties": {},
          "description": "Provider-specific configuration"
        },
        "subtype": {
          "type": "string",
          "description": "Resource subtype (e.g. 'linux' for compute, 'postgresql' for data)"
        },
        "aggregation": {
          "$ref": "#/definitions/Aggregation",
          "description": "v2.0 §8 — multiple identical resources"
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BlockRole"
          },
          "description": "v2.0 §9 — visual-only role indicators"
        },
        "subnetAccess": {
          "$ref": "#/definitions/SubnetAccess",
          "description": "Subnet access visibility — only meaningful for subnet-layer containers"
        },
        "profileId": {
          "type": "string",
          "description": "Visual profile preset identifier (frontend concern, serialized for persistence)"
        },
        "size": {
          "$ref": "#/definitions/Size"
        }
      },
      "required": [
        "category",
        "id",
        "kind",
        "layer",
        "metadata",
        "name",
        "parentId",
        "position",
        "provider",
        "resourceType",
        "size"
      ],
      "additionalProperties": false,
      "description": "A container node holds child nodes (VNet, Subnet, Resource Group, etc.). Containers have a size for visual rendering and can nest other containers or leaf resources."
    },
    "LayerType": {
      "type": "string",
      "enum": [
        "global",
        "edge",
        "region",
        "zone",
        "subnet",
        "resource"
      ],
      "description": "Layer hierarchy in the containment model. Ordered from broadest scope (global) to narrowest (resource)."
    },
    "ResourceCategory": {
      "type": "string",
      "enum": [
        "network",
        "security",
        "edge",
        "compute",
        "data",
        "messaging",
        "operations"
      ],
      "description": "Resource categories — the 7 canonical resource groups.\n\nMigration from 10 → 7:   compute   → compute   (was compute + function)   data      → data      (was database + storage)   edge      → edge      (was gateway)   security  → security  (was identity)   operations → operations (was analytics + observability)   messaging → messaging  (was queue + event) — empty in MVP   network   → network   (new — containers like VNet, Subnet)"
    },
    "ProviderType": {
      "type": "string",
      "enum": [
        "azure",
        "aws",
        "gcp"
      ],
      "description": "Cloud provider identifiers (alphabetical order — canonical)."
    },
    "Position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "description": "2D position with z-layer ordering."
    },
    "Aggregation": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/definitions/AggregationMode"
        },
        "count": {
          "type": "number",
          "description": "Must be >= 1"
        }
      },
      "required": [
        "mode",
        "count"
      ],
      "additionalProperties": false,
      "description": "Aggregation descriptor for node instances (v2.0 §8)."
    },
    "AggregationMode": {
      "type": "string",
      "enum": [
        "single",
        "count"
      ],
      "description": "Aggregation mode for block instances (v2.0 §8)."
    },
    "BlockRole": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "reader",
        "writer",
        "public",
        "private",
        "internal",
        "external"
      ],
      "description": "Block role indicators (v2.0 §9). Visual-only annotations that describe the function of a node."
    },
    "SubnetAccess": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ],
      "description": "Subnet access visibility."
    },
    "Size": {
      "type": "object",
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "depth": {
          "type": "number"
        }
      },
      "required": [
        "width",
        "height",
        "depth"
      ],
      "additionalProperties": false,
      "description": "3D bounding size."
    },
    "LeafNode": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "resource"
        },
        "layer": {
          "$ref": "#/definitions/LayerType",
          "description": "Hierarchy layer — used for containment validation"
        },
        "resourceType": {
          "type": "string",
          "description": "Specific resource identifier, e.g. 'virtual_network', 'vm', 'sql_database'"
        },
        "category": {
          "$ref": "#/definitions/ResourceCategory",
          "description": "One of the 7 resource categories"
        },
        "provider": {
          "$ref": "#/definitions/ProviderType"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent node ID. null for root-level nodes."
        },
        "position": {
          "$ref": "#/definitions/Position"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        },
        "config": {
          "type": "object",
          "additionalProperties": {},
          "description": "Provider-specific configuration"
        },
        "subtype": {
          "type": "string",
          "description": "Resource subtype (e.g. 'linux' for compute, 'postgresql' for data)"
        },
        "aggregation": {
          "$ref": "#/definitions/Aggregation",
          "description": "v2.0 §8 — multiple identical resources"
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BlockRole"
          },
          "description": "v2.0 §9 — visual-only role indicators"
        },
        "subnetAccess": {
          "$ref": "#/definitions/SubnetAccess",
          "description": "Subnet access visibility — only meaningful for subnet-layer containers"
        },
        "profileId": {
          "type": "string",
          "description": "Visual profile preset identifier (frontend concern, serialized for persistence)"
        }
      },
      "required": [
        "category",
        "id",
        "kind",
        "layer",
        "metadata",
        "name",
        "parentId",
        "position",
        "provider",
        "resourceType"
      ],
      "additionalProperties": false,
      "description": "A leaf resource node (VM, SQL Database, Redis Cache, etc.). Cannot contain children."
    },
    "Connection": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "sourceId": {
          "type": "string",
          "description": "ResourceNode or ExternalActor ID (initiator)"
        },
        "targetId": {
          "type": "string",
          "description": "ResourceNode or ExternalActor ID (receiver)"
        },
        "type": {
          "$ref": "#/definitions/ConnectionType"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "sourceId",
        "targetId",
        "type",
        "metadata"
      ],
      "additionalProperties": false,
      "description": "A typed connection between two resource nodes or external actors. Direction represents the **initiator** of the request; response flows implicitly in the reverse direction."
    },
    "ConnectionType": {
      "type": "string",
      "enum": [
        "dataflow",
        "http",
        "internal",
        "data",
        "async"
      ],
      "description": "Connection protocol/type between resource nodes. Direction represents the **initiator** of the request."
    },
    "ExternalActor": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "internet"
        },
        "position": {
          "$ref": "#/definitions/Position"
        }
      },
      "required": [
        "id",
        "name",
        "type",
        "position"
      ],
      "additionalProperties": false,
      "description": "An external actor represents an entity outside the architecture that initiates or receives connections (e.g., \"Internet\")."
    }
  }
}
