{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ArchitectureModel",
  "definitions": {
    "ArchitectureModel": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string",
          "description": "User-facing architecture revision (not schema version)"
        },
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Block"
          },
          "description": "All blocks — containers and resources in a flat array"
        },
        "endpoints": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Endpoint"
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Connection"
          }
        },
        "externalActors": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalActor"
          },
          "deprecated": "Folded into blocks in v4. Kept for v3→v4 migration loading."
        },
        "createdAt": {
          "type": "string",
          "description": "ISO 8601"
        },
        "updatedAt": {
          "type": "string",
          "description": "ISO 8601"
        }
      },
      "required": [
        "id",
        "name",
        "version",
        "nodes",
        "endpoints",
        "connections",
        "createdAt",
        "updatedAt"
      ],
      "additionalProperties": false,
      "description": "The root ArchitectureModel — the single most important type. This is the canonical JSON wire format exchanged between frontend persistence, backend validation, and code generation."
    },
    "Block": {
      "anyOf": [
        {
          "$ref": "#/definitions/ContainerBlock"
        },
        {
          "$ref": "#/definitions/ResourceBlock"
        }
      ],
      "description": "Discriminated union of all block types in the architecture. Discriminant: `kind` field ('container' | 'resource')."
    },
    "ContainerBlock": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "container"
        },
        "layer": {
          "$ref": "#/definitions/LayerType",
          "description": "Hierarchy layer — used for containment validation"
        },
        "resourceType": {
          "$ref": "#/definitions/ContainerCapableResourceType",
          "description": "Only container-capable resource types (virtual_network, subnet)"
        },
        "category": {
          "$ref": "#/definitions/ResourceCategory",
          "description": "One of the 8 resource categories"
        },
        "provider": {
          "$ref": "#/definitions/ProviderType"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent block ID. null for root-level blocks."
        },
        "position": {
          "$ref": "#/definitions/Position"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        },
        "config": {
          "type": "object",
          "additionalProperties": {},
          "description": "Provider-specific configuration"
        },
        "subtype": {
          "type": "string",
          "description": "Resource subtype (e.g. 'linux' for compute, 'postgresql' for data)"
        },
        "aggregation": {
          "$ref": "#/definitions/Aggregation",
          "description": "v2.0 §8 — multiple identical resources"
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BlockRole"
          },
          "description": "v2.0 §9 — visual-only role indicators"
        },
        "profileId": {
          "type": "string",
          "description": "Visual profile preset identifier (frontend concern, serialized for persistence)"
        },
        "canvasTier": {
          "$ref": "#/definitions/CanvasTier",
          "description": "Canvas structural tier — orthogonal to category (domain) and layer (hierarchy). Determines visual grouping on the canvas: shared, web, app, data. Optional during migration; defaults derived from RESOURCE_RULES."
        },
        "frame": {
          "$ref": "#/definitions/Size",
          "description": "Visual frame dimensions (width × height × depth)"
        }
      },
      "required": [
        "category",
        "frame",
        "id",
        "kind",
        "layer",
        "metadata",
        "name",
        "parentId",
        "position",
        "provider",
        "resourceType"
      ],
      "additionalProperties": false,
      "description": "A container block holds child blocks (VNet, Subnet, Resource Group, etc.). Containers have a frame (size) for visual rendering and can nest other containers or resource blocks."
    },
    "LayerType": {
      "type": "string",
      "enum": [
        "global",
        "edge",
        "region",
        "zone",
        "subnet",
        "resource"
      ],
      "description": "Layer hierarchy in the containment model. Ordered from broadest scope (global) to narrowest (resource)."
    },
    "ContainerCapableResourceType": {
      "type": "string",
      "enum": [
        "virtual_network",
        "subnet"
      ],
      "description": "Resource types that can be `kind: 'container'`."
    },
    "ResourceCategory": {
      "type": "string",
      "enum": [
        "network",
        "delivery",
        "compute",
        "data",
        "messaging",
        "security",
        "identity",
        "operations"
      ],
      "description": "Resource categories — the 8 canonical resource groups.\n\nMigration from 10 → 7 → 8:   compute    → compute    (was compute + function)   data       → data       (was database + storage)   delivery   → delivery   (renamed from edge; was gateway)   security   → security   (was identity in v6)   identity   → identity   (split from security; new in v8)   operations → operations (was analytics + observability)   messaging  → messaging  (was queue + event) — empty in MVP   network    → network    (new — containers like VNet, Subnet)"
    },
    "ProviderType": {
      "type": "string",
      "enum": [
        "azure",
        "aws",
        "gcp"
      ],
      "description": "Cloud provider identifiers (alphabetical order — canonical)."
    },
    "Position": {
      "type": "object",
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      },
      "required": [
        "x",
        "y",
        "z"
      ],
      "additionalProperties": false,
      "description": "2D position with z-layer ordering."
    },
    "Aggregation": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/definitions/AggregationMode"
        },
        "count": {
          "type": "number",
          "description": "Must be >= 1"
        }
      },
      "required": [
        "mode",
        "count"
      ],
      "additionalProperties": false,
      "description": "Aggregation descriptor for block instances (v2.0 §8)."
    },
    "AggregationMode": {
      "type": "string",
      "enum": [
        "single",
        "count"
      ],
      "description": "Aggregation mode for block instances (v2.0 §8)."
    },
    "BlockRole": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "reader",
        "writer",
        "public",
        "private",
        "internal",
        "external"
      ],
      "description": "Block role indicators (v2.0 §9). Visual-only annotations that describe the function of a block."
    },
    "CanvasTier": {
      "type": "string",
      "enum": [
        "shared",
        "web",
        "app",
        "data"
      ],
      "description": "Canvas tier — the structural grouping visible on the canvas. Orthogonal to both `category` (domain) and `layer` (hierarchy).\n\n- shared: cross-cutting resources (VNet, identity, monitoring)\n- web:    public-facing tier (load balancers, CDN, WAF)\n- app:    application tier (compute instances, functions)\n- data:   persistence tier (databases, caches, storage)"
    },
    "Size": {
      "type": "object",
      "properties": {
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "depth": {
          "type": "number"
        }
      },
      "required": [
        "width",
        "height",
        "depth"
      ],
      "additionalProperties": false,
      "description": "3D bounding size."
    },
    "ResourceBlock": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "const": "resource"
        },
        "layer": {
          "$ref": "#/definitions/LayerType",
          "description": "Hierarchy layer — used for containment validation"
        },
        "resourceType": {
          "type": "string",
          "description": "Specific resource identifier, e.g. 'virtual_network', 'web_compute', 'relational_database'"
        },
        "category": {
          "$ref": "#/definitions/ResourceCategory",
          "description": "One of the 8 resource categories"
        },
        "provider": {
          "$ref": "#/definitions/ProviderType"
        },
        "parentId": {
          "type": [
            "string",
            "null"
          ],
          "description": "Parent block ID. null for root-level blocks."
        },
        "position": {
          "$ref": "#/definitions/Position"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        },
        "config": {
          "type": "object",
          "additionalProperties": {},
          "description": "Provider-specific configuration"
        },
        "subtype": {
          "type": "string",
          "description": "Resource subtype (e.g. 'linux' for compute, 'postgresql' for data)"
        },
        "aggregation": {
          "$ref": "#/definitions/Aggregation",
          "description": "v2.0 §8 — multiple identical resources"
        },
        "roles": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/BlockRole"
          },
          "description": "v2.0 §9 — visual-only role indicators"
        },
        "profileId": {
          "type": "string",
          "description": "Visual profile preset identifier (frontend concern, serialized for persistence)"
        },
        "canvasTier": {
          "$ref": "#/definitions/CanvasTier",
          "description": "Canvas structural tier — orthogonal to category (domain) and layer (hierarchy). Determines visual grouping on the canvas: shared, web, app, data. Optional during migration; defaults derived from RESOURCE_RULES."
        }
      },
      "required": [
        "category",
        "id",
        "kind",
        "layer",
        "metadata",
        "name",
        "parentId",
        "position",
        "provider",
        "resourceType"
      ],
      "additionalProperties": false,
      "description": "A resource block (VM, SQL Database, Redis Cache, etc.). Cannot contain children."
    },
    "Endpoint": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "blockId": {
          "type": "string"
        },
        "direction": {
          "$ref": "#/definitions/EndpointDirection"
        },
        "semantic": {
          "$ref": "#/definitions/EndpointSemantic"
        }
      },
      "required": [
        "id",
        "blockId",
        "direction",
        "semantic"
      ],
      "additionalProperties": false,
      "description": "An Endpoint is a typed connection point on a block. Every block auto-generates 6 endpoints (3 semantics × 2 directions). Deterministic ID format: `endpoint-${blockId}-${direction}-${semantic}`"
    },
    "EndpointDirection": {
      "type": "string",
      "enum": [
        "input",
        "output"
      ],
      "description": "Direction of an endpoint on a block."
    },
    "EndpointSemantic": {
      "type": "string",
      "enum": [
        "http",
        "event",
        "data"
      ],
      "description": "Semantic type of an endpoint — determines what kind of traffic flows."
    },
    "Connection": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "from": {
          "type": "string",
          "description": "Endpoint ID (must be output direction)"
        },
        "to": {
          "type": "string",
          "description": "Endpoint ID (must be input direction)"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {}
        }
      },
      "required": [
        "id",
        "from",
        "to",
        "metadata"
      ],
      "additionalProperties": false,
      "description": "A connection between two endpoints (output → input). Both `from` and `to` must reference valid Endpoint IDs."
    },
    "ExternalActor": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "internet",
            "browser"
          ]
        },
        "position": {
          "$ref": "#/definitions/Position"
        }
      },
      "required": [
        "id",
        "name",
        "type",
        "position"
      ],
      "additionalProperties": false,
      "deprecated": "ExternalActors are folded into blocks in v4. Kept for v3→v4 migration."
    }
  }
}
